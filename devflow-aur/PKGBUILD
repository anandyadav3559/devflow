pkgname=devflow
pkgver=0.1.0
pkgrel=1
pkgdesc="Lightweight workflow orchestrator for local development"
arch=('x86_64')
url="https://github.com/anandyadav3559/devflow"
license=('MIT')
depends=('glibc') 
makedepends=('go')
source=("$pkgname-$pkgver.tar.gz::https://github.com/anandyadav3559/devflow/archive/refs/heads/main.tar.gz")
sha256sums=('SKIP')

build() {
  cd "$srcdir/$pkgname-main"
  export CGO_CPPFLAGS="${CPPFLAGS}"
  export CGO_CFLAGS="${CFLAGS}"
  export CGO_CXXFLAGS="${CXXFLAGS}"
  export CGO_LDFLAGS="${LDFLAGS}"
  export GOFLAGS="-buildmode=pie -trimpath -mod=readonly -modcacherw"
  
  go build -ldflags="-s -w -linkmode=external" -o devflow .
}

package() {
  cd "$srcdir/$pkgname-main"
  install -Dm755 devflow "$pkgdir/usr/bin/devflow"
  install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
}